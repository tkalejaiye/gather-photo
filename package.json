{
  "name": "gather-photo",
  "version": "0.1.0",
  "private": true,
  "description": "gather.photo — collect every guest's photos at an event via QR code. No app, no login.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
