# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server-only, never expose to client
SUPABASE_STORAGE_BUCKET=event-media

# Supabase resumable upload (TUS) endpoint
# e.g. https://<project>.supabase.co/storage/v1/upload/resumable
NEXT_PUBLIC_SUPABASE_TUS_ENDPOINT=

# Paystack
PAYSTACK_SECRET_KEY=              # server-only
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=          # for verifying webhook signatures

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth
# "true" shows "Continue with Google" on /sign-in. Leave off until the Google
# provider is configured in Supabase (FRI-38); with the flag on but the
# provider unconfigured, the button shows Supabase's error on click.
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false
